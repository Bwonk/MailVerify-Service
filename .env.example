# Application Environment
# Options: development, production, test
NODE_ENV=development

# Server Configuration
# Port number for the Express server
PORT=3000

# Database Configuration
# MySQL database host (e.g., localhost, or remote host)
DB_HOST=localhost

# MySQL database username
DB_USER=your_db_user

# MySQL database password
DB_PASSWORD=your_db_password

# MySQL database name
DB_NAME=email_verification_db

# AWS Configuration
# AWS region for SES service (yigitlabs.com uses eu-north-1)
AWS_REGION=eu-north-1

# AWS access key ID with SES send permissions
AWS_ACCESS_KEY_ID=your_aws_access_key_id

# AWS secret access key
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Email Configuration
# Sender email address (must be verified in AWS SES)
# For yigitlabs.com: no-reply@yigitlabs.com
SES_FROM_EMAIL=no-reply@yigitlabs.com

# Application Configuration
# Base URL for the application (used in verification links)
# For yigitlabs.com: https://yigitlabs.com
# For local development: http://localhost:3000
APP_BASE_URL=http://localhost:3000
